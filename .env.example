# ─── Database (Postgres — the single data backend) ──────────────────────────
# Local dev uses the dockerized Postgres from docker-compose.yml.
# In prod, point this at your hosted Postgres (e.g. Neon).
DATABASE_URL=postgresql://portfolio:portfolio@localhost:5440/portfolio2026

# ─── Admin gate ─────────────────────────────────────────────────────────────
# Comma-separated emails allowed to save. Must ALSO have the Firebase `admin`
# custom claim (set via `npm run seed:admin`).
ADMIN_EMAILS=b.fadamitan2019@gmail.com

# ─── Firebase (auth only — Google + Email/Password sign-in) ─────────────────
# Client config (safe to expose; from Firebase console → Project settings).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Admin SDK (server-only secret; from a service-account JSON).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the literal \n escapes; wrap the whole value in double quotes.
FIREBASE_PRIVATE_KEY=""

# ─── Cloudinary (image storage) ─────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

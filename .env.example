# ─── Database (Postgres — the single data backend) ──────────────────────────
# Local dev uses the dockerized Postgres from docker-compose.yml.
# In prod, point this at your hosted Postgres (e.g. Neon).
DATABASE_URL=postgresql://portfolio:portfolio@localhost:5441/portfolio2026

# ─── Admin gate (Google sign-in) ────────────────────────────────────────────
# Comma-separated emails allowed to save. The server verifies the Google ID
# token and grants admin only to a verified email in this list.
ADMIN_EMAILS=b.fadamitan2019@gmail.com

# OAuth 2.0 Web client ID (Google Cloud Console → APIs & Services → Credentials).
# The ONLY thing needed for "Sign in with Google" — no Firebase project/secret.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional: mirror ADMIN_EMAILS for *optimistic* client-side admin UI. The
# server gate above stays authoritative; omit to treat any sign-in as admin
# until the server corrects it.
NEXT_PUBLIC_ADMIN_EMAILS=b.fadamitan2019@gmail.com

# ─── Cloudinary (image storage) ─────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
